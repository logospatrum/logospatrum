# Database
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/patristic

# OpenAI-compatible model endpoint. Any provider (OpenAI, a Russian cloud
# proxy, a self-hosted vLLM, etc.) that speaks the OpenAI Chat Completions
# API works — point OPENAI_BASE_URL at it and supply the matching key.
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
MAIN_AGENT_MODEL=anthropic/claude-sonnet-4-6
SEARCH_AGENT_MODEL=anthropic/claude-haiku-4-5
ENRICH_MODEL=anthropic/claude-haiku-4-5

# Local LLM (LM Studio) — alternative for bulk enrich. Switch via
# ENRICH_PROVIDER=local in packages/pipeline/.env.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
ENRICH_PROVIDER=openai

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_WINDOW_MS=50

# Frontend
# Browser-visible: which URL the chat client hits. `/api` routes through the
# Next.js proxy (HMAC + budget guard); a direct backend URL bypasses anti-
# abuse and is for local debugging only.
NEXT_PUBLIC_API_URL=/api
# Server-side: where the Next.js /api proxy forwards. In prod compose this
# is the docker DNS name `http://backend:8000`; in local dev it's the
# uvicorn host.
BACKEND_URL=http://localhost:8000

# === Anti-abuse / RUB budget ===
# 32-byte hex (openssl rand -hex 32). REQUIRED in prod — empty disables HMAC
# verify and forces /budget/check / /session/refresh to 500.
PAT_SESSION_SECRET=

# nginx + backend CORS. Comma-separated list of explicit origins (NOT "*" —
# Starlette rejects allow_credentials=True with wildcard origins).
DOMAIN=localhost
ALLOWED_ORIGIN=https://localhost

# Daily caps in rubles. Every `/runs/stream` accumulates against THREE
# independent buckets — cookie (per-browser), ip (per-egress-IP), and fp
# (UA + Accept-Language + IP/24 hash, catches incognito-same-device). A run
# is blocked when ANY bucket is over its cap.
#   - COOKIE: per-person primary limit
#   - IP:     raises NAT/office collisions to acceptable cap
#   - FP:     stops "open incognito, reset cookie, repeat" abuse pattern
DAILY_RUB_PER_COOKIE=500
DAILY_RUB_PER_IP=250
DAILY_RUB_PER_FP=1000

# Warn ratio (0.8 = banner appears at 80% of daily limit).
SOFT_WARN_RATIO=0.8

# Global month kill-switch. When __global_month bucket exceeds this, all
# runs return 503 until the next month rolls over.
GLOBAL_MONTHLY_KILL_RUB=30000

# Rollback knob: set to false to disable both pre-run gate and post-run
# accounting (would-be charges are logged but not enforced/recorded).
BUDGET_GUARD_ENABLED=true

# === Container registry (VPS deploy only) ===
# PAT scoped to `read:packages` on the logospatrum org. Required at deploy
# time for `docker login ghcr.io`. NOT used by the running stack — only by
# `docker compose pull` on the VPS. Rotate via https://github.com/settings/tokens.
GHCR_USERNAME=
GHCR_TOKEN=
