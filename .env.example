# Database
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/patristic

# Timeweb AI Proxy (OpenAI-compatible)
TIMEWEB_AI_KEY=replace_me
TIMEWEB_BASE_URL=https://api.timeweb.ai/v1
MAIN_AGENT_MODEL=anthropic/claude-sonnet-4-7
SEARCH_AGENT_MODEL=anthropic/claude-haiku-4-5
ENRICH_MODEL=anthropic/claude-haiku-4-5

# Local LLM (LM Studio) for bulk enrich
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
ENRICH_PROVIDER=timeweb

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_WINDOW_MS=50

# Frontend
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_CATALOG_API_URL=http://localhost:8001
# Set to "/api" so the browser routes through the Next.js HMAC+budget proxy.
# Setting it to http://localhost:2024 directly bypasses anti-abuse security.
NEXT_PUBLIC_API_URL=/api

# === Anti-abuse / RUB budget ===
# 32-byte hex (openssl rand -hex 32). REQUIRED in prod — empty disables HMAC
# verify and forces /budget/check / /session/refresh to 500.
PAT_SESSION_SECRET=

# nginx + backend CORS. Comma-separated list of explicit origins (NOT "*" —
# Starlette rejects allow_credentials=True with wildcard origins).
DOMAIN=localhost
ALLOWED_ORIGIN=https://localhost

# Daily caps in rubles. Cookie-tracked browsers get the higher number;
# IP-fallback (curl, no-cookie clients) get the lower one.
DAILY_RUB_PER_COOKIE=500
DAILY_RUB_PER_IP=250

# Warn ratio (0.8 = banner appears at 80% of daily limit).
SOFT_WARN_RATIO=0.8

# Global month kill-switch. When __global_month bucket exceeds this, all
# runs return 503 until the next month rolls over.
GLOBAL_MONTHLY_KILL_RUB=30000

# Rollback knob: set to false to disable both pre-run gate and post-run
# accounting (would-be charges are logged but not enforced/recorded).
BUDGET_GUARD_ENABLED=true
