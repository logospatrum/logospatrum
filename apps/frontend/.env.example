# Browser-visible: which URL the chat client hits. `/api` routes through the
# Next.js proxy (HMAC + budget guard); a direct URL like
# `http://localhost:8000` bypasses that and is for local debugging only.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_ASSISTANT_ID=patristic

# Server-side: where the Next.js /api proxy forwards. In prod compose it's
# the docker DNS name `http://backend:8000`; in local dev it's the uvicorn
# host that runs `backend.server:app`.
BACKEND_URL=http://localhost:8000

# Yandex Metrika counter ID (number, no quotes). Leave empty in dev so the
# script doesn't load and goals don't pollute the prod counter. Set in prod
# at build time — NEXT_PUBLIC_* is inlined by `next build`, not read at
# runtime, so it must be present in the build environment (CI / Dockerfile
# build-arg).
NEXT_PUBLIC_YM_COUNTER_ID=
NEXT_PUBLIC_AUTH_SCHEME=
